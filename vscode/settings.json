{
    // WELL THAT'S DUMB (make it less dumb)
    // 2023-01-26 the following no longer works:
    "keyboard.dispatch": "keyCode", // caps lock as ctrl should work as expected
    "editor.minimap.enabled": false, // no clutter pls
    "window.customMenuBarAltFocus": false,
    "editor.cursorBlinking": "solid",
    "glassit.alpha": 240, // tabs are annoying to close, can I just...disable them? No. This hides them.
    "zenMode.hideStatusBar": false, // Zen mode is great, but disable some zen-mode defaults
    "zenMode.hideLineNumbers": false,
    "zenMode.centerLayout": false,
    "zenMode.hideActivityBar": false,
    "window.titleBarStyle": "custom", // hide gross top bar
    "security.workspace.trust.untrustedFiles": "open",
    "workbench.startupEditor": "none", // statusbar at bottom
    "explorer.confirmDragAndDrop": false, // no confirm on drag/drop file
    "editor.inlineSuggest.enabled": true, // preview suggestions inline in greyed out text
    "editor.fontLigatures": true,
    "editor.fontFamily": "Fira Code", // ligature supporting font
    "editor.fontWeight": "500",
    "breadcrumbs.enabled": false, // reduce UI clutter, hide breadcrumbs
    "terminal.integrated.fontFamily": "MesloLGS NF", // terminal font bug pls no
    "terminal.integrated.fontWeight": "bold",
    "terminal.integrated.defaultProfile.linux": "fish",
    "workbench.colorTheme": "Moonlight II",
    "editor.tabSize": 2, // prefer 2-space width. Disable to automatically configure.

    // SAVE AND FORMAT OFTEN
    "editor.formatOnSaveMode": "file",
    "files.autoSave": "afterDelay", // other options are suprisingly bad
    "files.autoSaveDelay": 500, // ms
    // "editor.formatOnSave": true, // does nothing if save after delay
    "editor.formatOnType": false, // BUGGGYYYYY, turn off. Eg, inserts $0 after typing '<' in rust
    "editor.formatOnPaste": true,

    // GENERAL CODING SETTINGS
    // "editor.foldingImportsByDefault": true,
    "search.smartCase": true, // figure out whether I care about case-sensitivity
    "editor.tabCompletion": "on", // complete snippets w tab 
    // "editor.wordWrap": "wordWrapColumn", // if I wrote it, I want it on screen
    "editor.wordWrap": "on", // hard break at 120. Soft wrap is called "bounded". defaults to off.
    "editor.wordWrapColumn": 120,
    "rewrap.autoWrap.enabled": true, // simple ext to automatically word-wrap my comments

    // GIT OPS and LENS
    "git.autofetch": true,
    "diffEditor.codeLens": true, // show clicky buttons in merge rebases

    // ERROR SETTINGS
    "errorLens.delay": 1000, // doesn't appear to do what I'd think it would
    "errorLens.enableOnDiffView": true, // view errors on diff
    "errorLens.statusBarIconsEnabled": true,
    "errorLens.enabled": false, // toggle this often
    "errorLens.enabledDiagnosticLevels": [
        "warning",
        "error"
    ],

    // MISC CODING SETTINGS
    // Make suggestions suck less. see: https://code.visualstudio.com/docs/editor/intellisense#_types-of-completions
    "editor.suggest.showDeprecated": false, // def: true; don't show deprecations in suggests
    "editor.suggest.showWords": false, // show me ghost outline of what suggest will fill
    "editor.suggest.snippetsPreventQuickSuggestions": false, // I like my snippets to have suggestions
    "editor.inlayHints.enabled": "offUnlessPressed", // toggle with ctrl-alt
    // OPTION: migrate snippets out of VSCode to espanso OS snippets system.
    // "editor.snippetSuggestions": "top", // I like my snippets 

    //\//\//\//\//\
    ///// VIM \\\\\
    //\//\//\//\//\
    // docs: https://github.com/VSCodeVim/Vim
    // To grab a block at some indentation level, use <operater>{ii,ai} for inside block, or block and above.
    // I read up to Input Method, the rest might be info overload.
    // with noun a=args: cia - change the arg under the cursor preserving comma separators
    // see bottom for key remappings
    "vim.leader": "<space>",
    "vim.sneak": true, // module: jump to char after "s<char><char>". Uses 'z' in operator mode. 
    "vim.sneakReplacesF": true, // replace f w/ single-char sneak, wraps around lines
    "vim.sneakUseIgnorecaseAndSmartcase": true, // smart case good
    // "vim.easymotion": true, // less ergonomic n' more complex than vim-sneak.
    "vim.argumentObjectOpeningDelimiters": [ "<", "(", "[", "{" ],
    "vim.argumentObjectClosingDelimiters": [ ">", ")", "]", "}" ],
    // usage: ldr ldr {sftwblhjk}
    "vim.foldfix": true, // don't unfold code when I move over it
    "vim.camelCaseMotion.enable": true, // enable camel-case based motions
    "vim.surround": true, // use surrounding pairs as nouns.  
    // usage: wrap a word with quotes: ysiw"; delete/change surrounding quotes: {dc}s"
    // in visual mode, use cap S" to surround a selection with quotes <- underused tip
    "vim.useSystemClipboard": true,
    "vim.joinspaces": false, // 2 spaces on joining is nonsense
    "vim.highlightedyank.enable": true, // briefly flash yanks
    "vim.hlsearch": true, // highlight all matches

    //\//\//\//\//\/
    ///// RUST \\\\\
    //\//\//\//\//\/
    // cargo: https://doc.rust-lang.org/cargo/reference/features.html
    // RA: https://rust-analyzer.github.io/manual.html#configuration
    "rust-analyzer.check.command": "clippy",
    "rust-analyzer.diagnostics.experimental.enable": false, // def: false, match <>
    "rust-analyzer.imports.granularity.enforce": true, // group imports
    "rust-analyzer.rustfmt.rangeFormatting.enable": true, // get rid of this line when rangeformatting goes stable
    "rust-analyzer.typing.autoClosingAngleBrackets.enable": false, // Can't get VS code to intelligently skip '>'
    "[rust]": {
        // language keywords tend to get in way of snippets, but are useful in less familiar languages
        "editor.suggest.showKeywords": false,
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
    },
    "rust-analyzer.cargo.features": "all", // uncomment to check features (not greyed out)
    // IF RUST-ANALYZER IS TOO SLOW, UNCOMMENT:
    "rust-analyzer.checkOnSave": false, // uncomment if rust is slow
    "cargo.automaticCheck": false,
    // "rust-analyzer.cargo.autoreload": false, // stops cargo from reloading on toml changes

    //\//\//\//\//\///
    ///// PYTHON \\\\\
    //\//\//\//\//\///
    // https://stackoverflow.com/questions/50177173/how-do-i-get-flake8-to-reliably-ignore-rules-in-vs-code
    "[python]": {
        "editor.tabSize": 2,
        "editor.formatOnType": true
    },
    "python.linting.flake8Args": [ "--max-line-length=120", "--ignoreE=402,F841,F401,E302,E305", ],
    "python.formatting.autopep8Args": [ "--ignore", "E302,E305,F401,F841"],
        // ,F84k1,F401,E302,E305" // "--ignore 402,F84k1,F401,E302,E305"
    "python.linting.flake8Enabled": true,
    "python.analysis.typeCheckingMode": "basic",


    // VIM REMAPPINGS 
    // JSON formatting makes the following annoying, disable it
    "json.format.enable": false,
    "vim.debug.silent": true, // don't bother me 
    // note: use non-recursive binding to avoid recursive chains of bindings
    "vim.insertModeKeyBindings": [
        // go to normal if accidentally start using normal-mode movements
        { "before": [ "k", "k" ], "after": [ "<Esc>" ] },
        { "before": [ "j", "j" ], "after": [ "<Esc>" ] },
        { "before": [ "k", "j" ], "after": [ "<Esc>" ] },
        { "before": [ "j", "k" ], "after": [ "<Esc>" ] }
    ],
    // aocrehuacorehu aoecrhua oceuh acoeua hoe
    "vim.normalModeKeyBindingsNonRecursive": [ 
        // unite undo/redo's with VS Code's
        { "before": [ "u" ], "commands": [ "undo" ] },
        { "before": [ "U" ], "commands": [ "redo" ] },
        // movement nouns; respect camel/snakecase
        { "before": [ "b" ], "after": [ "<leader>", "b", ] },
        { "before": [ "e" ], "after": [ "<leader>", "e", ] },
        { "before": [ "w" ], "after": [ "<leader>", "w", ] },
        { "before": [ "L" ], "after": [ "$", ] },
        { "before": [ "H" ], "after": [ "^", ] },
        // { "before": [ ">" ], "after": [ ">>", ] }, // nope
        // { "before": [ "<" ], "after": [ "<<", ] }, // nope
        // { "before": [ ";" ], "commands": [ "cursorPageDown", ] },
        // { "before": [ ":" ], "commands": [ "cursorPageUp", ] },
        { "before": [ "H" ], "after": [ "^", ] },
        // verb updates, eg toggling case/position, macros, etc
        { "before": [ "T" ], "after": [ "~" ] },
        { "before": [ "t" ], "commands": [ "editor.action.transpose" ] },
        { "before": [ "m" ], "after": [ "@" ] },
        // quickly find and fix problems
        { "before": [ "+" ], "commands": [ "editor.action.marker.next", ] },
        { "before": [ "=" ], "commands": [ "editor.action.quickFix" ] }, 
        // g operators
        { "before": [ "g", "d" ], "commands": [ "editor.action.peekDefinition"] },
        { "before": [ "g", "D" ], "commands": [ "editor.action.revealDefinition" ] },
        { "before": [ "g", "i" ], "commands": [ "editor.action.peekDefinition"] },
        { "before": [ "g", "t" ], "commands": [ "editor.action.peekTypeDefinition"] },
        { "before": [ "g", "T" ], "commands": [ "editor.action.goToTypeDefinition"] },
        { "before": [ "g", "m" ], "commands": [ "editor.action.peekImplementation"] },
        { "before": [ "g", "M" ], "commands": [ "editor.action.goToImplementation"] },
        { "before": [ "g", "r" ], "commands": [ "editor.action.referenceSearch.trigger"] },
        { "before": [ "g", "R" ], "commands": [ "editor.action.goToReferences"] },
        { "before": [ "g", "/" ], "commands": [ "editor.action.revealDefinitionAside" ] },

        // changes
        { "before": [ "]", "]" ], "commands": [ "workbench.action.navigateBack" ] },
        { "before": [ "[", "[" ], "commands": [ "workbench.action.navigateForward" ] },
        { "before": [ "[", "c" ], "commands": [ "workbench.action.editor.previousChange" ] },
        { "before": [ "]", "c" ], "commands": [ "workbench.action.editor.nextChange" ] },
        { "before": [ "[", "r" ], "commands": [ "references-view.previous" ] },
        { "before": [ "]", "r" ], "commands": [ "references-view.next" ] },
        { "before": [ "[", "s" ], "commands": [ "editor.action.wordHighlight.previous" ] },
        { "before": [ "]", "s" ], "commands": [ "editor.action.wordHighlight.next" ] },
        { "before": [ "[", "p" ], "commands": [ "editor.action.marker.prev" ] },
        { "before": [ "[", "P" ], "commands": [ "editor.action.marker.prevInFiles" ] },
        { "before": [ "]", "p" ], "commands": [ "editor.action.marker.next" ] },
        { "before": [ "]", "P" ], "commands": [ "editor.action.marker.nextInFiles" ] },
        { "before": [ "[", "m" ], "commands": [ "merge.goToPreviousUnhandledConflict" ] },
        { "before": [ "]", "m" ], "commands": [ "merge.goToNextUnhandledConflict" ] },
        { "before": [ "[", "t" ], "commands": [ "testing.goToPreviousMessage" ] },
        { "before": [ "]", "t" ], "commands": [ "testing.goToNextMessage" ] },
        
        // { "before": [ "\\" ], "commands": [ "cursorPageDown" ] }, 
        // https://vspacecode.github.io/docs/whichkey/
        { "before": ["<leader>"], "commands": ["whichkey.show"]}
    ], 
    // mirror movement nouns to operator and visual modes, and verbs to visual mode
    "vim.operatorPendingModeKeyBindingsNonRecursive": [ 
        { "before": [ "b" ], "after": [ "<leader>", "b", ] },
        { "before": [ "e" ], "after": [ "<leader>", "e", ] },
        { "before": [ "w" ], "after": [ "<leader>", "w", ] },
        { "before": [ "L" ], "after": [ "$", ] },
        { "before": [ "H" ], "after": [ "^", ] },
    ],
    "vim.visualModeKeyBindingsNonRecursive": [ 
        { "before": [ "b" ], "after": [ "<leader>", "b", ] },
        { "before": [ "e" ], "after": [ "<leader>", "e", ] },
        { "before": [ "w" ], "after": [ "<leader>", "w", ] },
        { "before": [ "L" ], "after": [ "$", ] },
        { "before": [ "H" ], "after": [ "^", ] },
        { "before": [ "T" ], "after": [ "~" ] },
        { "before": ["<leader>"], "commands": ["whichkey.show"]}
    ],

    //\/\/\//\\//\\//\\\///\
    // WHICH KEY BINDINGS //
    //\/\/\//\\//\\//\\\///\
    // ref: https://vspacecode.github.io/docs/whichkey/
    "whichkey.delay": 100,  // millis, default 0
    "whichkey.sortOrder": "custom", // put custom bindings near top
    "whichkey.bindingOverrides": [
        // debug wishlist:
        // - RA debug - this can be used to debug tests outside the executable (currently spc r d)
        // - RA view HIR: see desugared Rust 
        // - RA memory usage - can see what's hogging memory
        { "keys": "e", "name": "+Error Lens", "type": "bindings", "bindings": [
            { "key": " ", "name": "Toggle all", "type": "command", "command": "errorLens.toggle", },
            { "key": "c", "name": "Toggle copy", "type": "command", "command": "errorLens.copyProblemMessage", },
            { "key": "e", "name": "Toggle errors", "type": "command", "command": "errorLens.toggleError", },
            { "key": "h", "name": "Toggle hint", "type": "command", "command": "errorLens.toggleHint", },
            { "key": "i", "name": "Toggle info", "type": "command", "command": "errorLens.toggleInfo", },
            { "key": "w", "name": "Toggle warning", "type": "command", "command": "errorLens.toggleWarning", },
          ]},
        { "keys": "f", "name": "+Files", "type": "bindings", "bindings": [
            { "key": "d", "name": "New directory", "type": "command", "command": "fileutils.newFolder", },
            { "key": "e", "name": "Reaveal in file explorer", "type": "command", "command": "workbench.files.action.showActiveFileInExplorer", },
            { "key": "f", "name": "Open file in workspace", "type": "command", "command": "workbench.action.quickOpen", },
            { "key": "k", "name": "Remove file", "type": "command", "command": "fileutils.removeFile", },
            { "key": "m", "name": "Move file", "type": "command", "command": "fileutils.moveFile", },
            { "key": "n", "name": "New file", "type": "command", "command": "fileutils.newFile", },
            { "key": "r", "name": "Rename file", "type": "command", "command": "fileutils.renameFile", },
            { "key": "s", "name": "Open recent editor", "type": "command", "command": "workbench.action.openRecent", },
            { "key": "w", "name": "Open recent workspace", "type": "command", "command": "workbench.action.openRecent", },
        ]},
        { "keys": "o", "name": "+Focus", "type": "bindings", "bindings": [
            { "key": "d", "name": "Focus Debugger", "type": "command", "command": "workbench.panel.repl.view.focus", },
            { "key": "e", "name": "Focus Explorer", "type": "command", "command": "workbench.files.action.focusFilesExplorer", },
            { "key": "f", "name": "Focus Explorer Folders", "type": "command", "command": "workbench.explorer.fileView.focus", },
            { "key": "o", "name": "Focus Panel", "type": "command", "command": "workbench.action.focusPanel", },
            { "key": "p", "name": "Focus Problems", "type": "command", "command": "workbench.action.problems.focus", },
            { "key": "t", "name": "Focus Terminal", "type": "command", "command": "workbench.action.terminal.focus", },
            { "key": "x", "name": "Focus Extensions", "type": "command", "command": "workbench.extensions.action.showEnabledExtensions", },
            { "key": "O", "name": "Focus Explorer Outline", "type": "command", "command": "outline.focus", },

        ]},
        { "keys": "p", "name": "+Python", "type": "bindings", "bindings": [
            { "key": "d", "name": "Debug in Terminal", "type": "command", "command": "python.debugInTerminal", },
            { "key": "f", "name": "Format", "type": "command", "command": "editor.action.formatDocument", },
            { "key": "l", "name": "Lint", "type": "command", "command": "python.runLinting", },
            { "key": "i", "name": "Start repl", "type": "command", "command": "python.startREPL", },
            { "key": "n", "name": "Create new Python File", "type": "command", "command": "python.createNewFile", },
            { "key": "r", "name": "Run Python File", "type": "command", "command": "python.execInTerminal-icon", },
            //exp: { "key": "r", "name": "Run Python File", "type": "command", "command": "python.execInTerminal", },
            { "key": "t", "name": "Create Terminal", "type": "command", "command": "python.createTerminal", },
            { "key": "v", "name": "View output", "type": "command", "command": "python.viewOutput", },

            { "key": "L", "name": "Toggle Linting", "type": "command", "command": "python.enableLinting", },
            { "key": "O", "name": "Open in Terminal", "type": "command", "command": "python.envManager.openInTerminal", },
            { "key": "R", "name": "Run in python terminal", "type": "command", "command": "python.execSelectionInTerminal", },
            { "key": "T", "name": "Configure Tests", "type": "command", "command": "python.configureTests", },
        ]},
        { "keys": "t", "name": "+Toggles", "type": "bindings", "bindings": [
            { "key": "a", "name": "Toggle Activity Bar", "type": "command", "command": "workbench.action.toggleActivityBarVisibility", },
            { "key": "b", "name": "Toggle Sidebar", "type": "command", "command": "workbench.action.toggleSidebarVisibility", },
            { "key": "d", "name": "Toggle Debug Repl", "type": "command", "command": "workbench.debug.action.toggleRepl", },
            { "key": "e", "name": "Toggle Editor Visibility", "type": "command", "command": "workbench.action.toggleEditorVisibility", },
            { "key": "n", "name": "Clear Notifications", "type": "command", "command": "notifications.clearAll", },
            { "key": "p", "name": "Toggle Panel", "type": "command", "command": "workbench.action.togglePanel", },
            { "key": "r", "name": "Toggle Problems", "type": "command", "command": "workbench.action.tasks.toggleProblems", },
            { "key": "t", "name": "Toggle Terminal", "type": "command", "command": "workbench.action.terminal.toggleTerminal", },
            { "key": "z", "name": "Toggle Zen Mode", "type": "command", "command": "workbench.action.toggleZenMode", },
            { "key": "/", "name": "Toggle Horizontal/Vertical", "type": "command", "command": "workbench.action.toggleEditorGroupLayout", },

            { "key": "O", "name": "Toggle Maximized panel", "type": "command", "command": "workbench.action.output.toggleOutput", },
            { "key": "P", "name": "Toggle Maximized panel", "type": "command", "command": "workbench.action.toggleMaximizedPanel", },
            { "key": "T", "name": "Toggle Tab Bar", "type": "command", "command": "workbench.action.toggleTabsVisibility", },
        ]},
        { "keys": "r", "name": "+Rust", "type": "bindings", "bindings": [
            { "key": "a", "name": "Add", "type": "command", "command": "cargo.add", },
            { "key": "b", "name": "Build", "type": "command", "command": "cargo.build", },
            { "key": "c", "name": "Check", "type": "command", "command": "cargo.check", },
            { "key": "d", "name": "Debug", "type": "command", "command": "rust-analyzer.debug", },
            { "key": "f", "name": "Format", "type": "command", "command": "editor.action.formatDocument", },
            { "key": "p", "name": "Parent Module", "type": "command", "command": "rust-analyzer.parentModule", },
            { "key": "r", "name": "Run", "type": "command", "command": "rust-analyzer.run", },
            { "key": "t", "name": "Open Cargo.toml", "type": "command", "command": "rust-analyzer.openCargoToml", },
            { "key": "/", "name": "Structural search replace", "type": "command", "command": "rust-analyzer.ssr", },

            { "key": "D", "name": "Open Docs", "type": "command", "command": "rust-analyzer.openDocs", },
            { "key": "E", "name": "Expand Macro", "type": "command", "command": "rust-analyzer.expandMacro", },
            { "key": "I", "name": "Init Server", "type": "command", "command": "rust-analyzer.startServer", },
            { "key": "H", "name": "View HIR", "type": "command", "command": "rust-analyzer.viewHir", },
            { "key": "K", "name": "Kill Server", "type": "command", "command": "rust-analyzer.stopServer", },
            { "key": "P", "name": "Peek Tests", "type": "command", "command": "rust-analyzer.peekTests", },
            { "key": "R", "name": "Reload", "type": "command", "command": "rust-analyzer.reload", },
            { "key": "S", "name": "Syntax tree", "type": "command", "command": "rust-analyzer.syntaxTree", },
          ]
        },

            // { "keys": "r", "name": "+Extra", "type": "bindings", "bindings": [
            //     { "key": "x", "name": "run", "type": "command", "command": "rust-analyzer.run", },
            // ]},
            // todo
        // replaces errors:
        // { "keys": "x", "name": "Explorer...", "type": "bindings", "bindings": [
        //     { "key": "x", "name": "Explorer", "type": "command", "command": "workbench.view.explorer", },
        // ]},
        { "keys": "/", "name": "+Search", "type": "bindings", "bindings": [
            { "key": "r", "name": "Replace", "type": "command", "command": "workbench.action.replaceInFiles", },
            { "key": "/", "name": "Search", "type": "command", "command": "workbench.view.search.focus", },
            // todo
          ]},
        { "keys": ",", "name": "+Settings", "type": "bindings", "bindings": [
            { "key": "j", "name": "Json Settings", "type": "command", "command": "workbench.action.openSettingsJson", },
            { "key": "k", "name": "Bindings", "type": "command", "command": "workbench.action.openGlobalKeybindings", },
            { "key": "s", "name": "Settings", "type": "command", "command": "workbench.action.openSettings", },
            { "key": "x", "name": "Extensions", "type": "command", "command": "workbench.view.extensions", },
          ]},
          { "keys": "1", "position": "-1"},
          { "keys": "2", "position": "-1"},
          { "keys": "3", "position": "-1"},
          { "keys": "4", "position": "-1"},
          { "keys": "5", "position": "-1"},
          { "keys": "6", "position": "-1"},
          { "keys": "7", "position": "-1"},
          { "keys": "8", "position": "-1"},
          { "keys": "*", "position": "-1"},
        //   { "keys": ".", "position": "-1"},
          { "keys": " ", "position": "-1"},
          { "keys": "!", "position": "-1"},
          { "keys": "i", "position": "-1"},
          { "keys": "v", "position": "-1"},
          { "keys": "x", "position": "-1"},
          { "keys": "T", "position": "-1"},
          { "keys": "z", "position": "-1"},
    ],

    // don't show these in explorer
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "Cargo.lock": true,
        "target": true,
        "APACHE2": true,
        "LICENSE*": true,
        ".taplo*": true,
        ".clippy*": true,
        ".rustfmt*": true,
        "**/*.olean": true
    },
    "jupyter.widgetScriptSources": [
      "jsdelivr.com",
      "unpkg.com"
    ],
    "window.menuBarVisibility": "compact",
    "workbench.sideBar.location": "right",
    "editor.multiCursorModifier": "ctrlCmd",
    "workbench.editor.showTabs": false,
    "explorer.confirmDelete": false,
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "github.copilot.enable": {
        "*": true,
        "yaml": true,
        "plaintext": false,
        "markdown": false
    },
    "workbench.activityBar.visible": false,
    "window.zoomLevel": -1,
}