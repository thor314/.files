{
	// prefix item level most with an x, to avoid completion collision
	// allows
	"all allows": {
		"prefix": ["xa", "#![allow"],
		"body":  ["#![allow(unused_imports)]", "#![allow(unused_variables)]", "#![allow(dead_code)]" ]
	},
	"allow unused imports": {
		"prefix": ["xai"],
		"body":  "#[allow(unused_imports)]",
	},
	"allow unused varaibles": {
		"prefix": ["xav"],
		"body":  "#[allow(unused_variables)]",
	},
	"allow dead code": {
		"prefix": ["xad"],
		"body":  "#[allow(dead_code)]",
	},
	// prefix METHODS and FUNCTIONS with y, would be nice to migrate these to rust snippets if possible.
	"dbg": {
		"prefix": ["ydbg", "dbg"],
		"body":  "dbg!($1);",
	},
	"println": {
		"prefix": ["yp","ypl"],
		"body":  "println!(\"{$1:?}\");",
	},
	"println extended": {
		"prefix": ["ypln","println"],
		"body":  "println!(\"$1: {$1:?}\");",
	},
	"eprintln": {
		"prefix": ["yepl"],
		"body":  "eprintln!(\"{$1:?}\");",
	},
	"eprintln extended": {
		"prefix": ["yepln", "eprintln"],
		"body":  "eprintln!(\"$1: {$1:?}\");",
	},
	"format": {
		"prefix": ["yf", "format"],
		"body":  "format!(\"{}$1{}\");",
	},
	// TYPES: no prefix, capital letter. would be nice to migrate these to rust snippets if possible.
	"Option": {
		"prefix": "Option",
		"body": "Option<$1>",
	},
	"Ok": {
		"prefix": "Ok",
		"body": "Ok<$1>",
	},
	"Error": {
		"prefix": "Error",
		"body": "Error<$1>",
	},
	"Anyhow Result": {
		"prefix": ["AResult","-> AResult"],
		"body": "-> Result<${1:()}>",
	},
	"Result": {
		"prefix": ["Result","-> Result"],
		"body": "-> Result<${1:()}, Box<dyn std::error::Error>>",
	},
	// KEYWORDS: keywords with z
	"let mut": {
		"prefix": ["zlm", "let mut"],
		"body": "let mut $1 = $2;",
	},
	"if": {
		"prefix": ["zif", "if"],
		"body": "if $1 { $2 }",
	},
	"if let": {
		"prefix": ["zifl", "if let"],
		"body": "if let Some($1) = $2 { $3 }",
	},
	"match": {
		"prefix": ["zm","match"],
		"body": "match $1 {\n $2 => $3,\n $4 }",
	},
	// ITEMS: prefix with z
	"pub(crate)":{
		"prefix": ["zp"],
		"body": "pub(crate) "
	},
	"fn": {
		"prefix": ["zf"],
		"body": "fn $1($2) {\n\t$3\n\ttodo!();\n}"
	},
	"fn returns": {
		"prefix": ["zfr"],
		"body": "fn $1($2) -> $3 {\n\t$4\n\ttodo!();\n}"
	},
	"fn returns result": {
		"prefix": ["zfrr"],
		"body": "fn $1($2) -> Result<${3:()}, std::error::Error> {\n\t$4\n\ttodo!();\n}"
	},
	"async fn": {
		"prefix": ["zaf","async"],
		"body": "async fn $1($2) {\n\t$3\n\ttodo!();\n}"
	},
	"async fn returns": {
		"prefix": ["zafr"],
		"body": "async fn $1($2) -> $3 {\n\t$4\n\ttodo!()\n}"
	},
	"async fn returns result": {
		"prefix": ["zafnrr"],
		"body": "fn $1($2) -> Result<${3:()}, Box<dyn std::error::Error>> {\n\t$4\n\ttodo!()\n}"
	},
	"fn main": {
		"prefix": ["zm","main"],
		"body": "fn main() {\n\t$1\n}"
	},
	"fn main result": {
		"prefix": ["zmr","mainr"],
		"body": "fn main() -> Result<${1:()}, Box<dyn std::error::Error>> {\n\t$2;\n\ttodo!();\n}"
	},
	"tokio main fn": {
		"prefix": ["zam","amain"],
		"body": "#[tokio::main]\nasync fn main() {\n\t$1\n}"
	},
	"tokio main fn result": {
		"prefix": ["zamr","amainr","#[tokio::main"],
		"body": "#[tokio::main]\nfn main() -> Result<${1:()}, Box<dyn std::error::Error>> {\n\t$2\n\tOk(());\n}"
	},
	"test fn": {
		"prefix": ["zt", "#[test"],
		"body": "#[test]\nfn test_$1(){\n\ttodo!();\n}",
	},
	"test mod": {
		"prefix": ["modt", "tm", "mod test"],
		"body": "#[cfg(test)]\nmod test{\n\tuse super::*;\n\t#[test]\n\tfn test_$1(){\n\t\ttodo!();\n\t}\n}",
	},
	// STRUCTS, ENUMS
	"struct": {
		"prefix": ["zs"],
		"body": "struct $1{\n\t$2\n}",
	},
	"struct w new": {
		"prefix": ["zsn","structnew"],
		"body": ["struct $1{\n\t$2\n}\n\nimpl $1{",
			"\tpub fn new() -> Self{",
			"\t\t{Self$3{}\n}}}"],
	},
	// Useful when would otherwise require many constructors or where construction has side effects.
	// ref: https://rust-unofficial.github.io/patterns/patterns/creational/builder.html
	"struct w builder": {
		"prefix": ["zsb","structbuilder"],
		"body": ["pub struct $1{\n\t$2\n}\n\nimpl $1{",
			"\tpub fn builder() -> ${1}Builder{",
			"\t\t{${1}Builder::default()}\n}}",
			"#[derive(Default)]\npub struct ${1}Builder{",
			"\tname: String,\n\t$2\n}\n",
			"impl ${1}Builder {",
			"\tpub fn new() -> ${1}Builder{ Self{$3} }",
			"\t/// Set some parameter on the builder, return the builder. Add more methods like this.",
			"\tpub fn name(mut self, name: String) -> ${1}Builder{ self.name = name; self }",
			"\t/// Produce $1, consuming ${1}Builder",
			"\tpub fn build(self) -> $1 { $1 { $3 } }",
			"}"],
	},
	"impl w new": {
		"prefix": ["zin","impl new"],
		"body": ["impl $1{",
			"\tpub fn new() -> Self{",
			"\t\t{Self{\n}\n}}}"],
	},
	"derive Debug": {
		"prefix": ["zdd", "#[derive(D"],
		"body": "#[derive(Debug)]",
	},
	"derive Clone": {
		"prefix": ["zdc", "#[derive(C"],
		"body": "#[derive(Clone)]",
	},
	"derive Debug,Clone": {
		"prefix": ["zddc", "#[derive(DC"],
		"body": "#[derive(Debug, Clone)]",
	},
	"derive struct":{
		"prefix": ["zds","struct"],
		"body": [
			"#[derive(Debug,Clone,Default)]",
			"struct $1{\n\t$2\n}\n\nimpl $1{",
			"\tpub fn new() -> Self{",
			"\t\t{Self$3{}\n}}}"],
	},
	"enum": {
		"prefix": ["zde","enum"],
		"body": "enum $1{\n\t$2\n}",
	},
	"derive enum": {
		"prefix": ["zde","enum"],
		"body": [
			"#[derive(Debug,Clone,Default)]",
			"enum $1{\n\t$2\n}",]
		}
	// Design patterns https://rust-unofficial.github.io/patterns/

}